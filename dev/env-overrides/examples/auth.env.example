# Auth mode. Applied to API and management-api by make local_env_setup (local), or merged into K8s env by render-k8s-env.sh (alpha/beta/prod).
# admin_only_username | admin_only_email | user_signup_email.
# Canonical example in dev/env-overrides/examples/. Seeded to ~/.config/boilerplate/<local-env-overrides|alpha-env-overrides>/ by make local_env_prepare or make alpha_env_prepare; link creates dev/env-overrides/<env>/*.env pointing at home.

AUTH_MODE="admin_only_username"
