# Management DB superuser bootstrap. Set manually; not generated by local setup.
# Used when creating the initial superuser (e.g. make local_management_db_init). K8s uses these values in rendered secrets when present.
# Canonical example in dev/env-overrides/examples/. Seeded to ~/.config/boilerplate/<local-env-overrides|alpha-env-overrides>/ by make local_env_prepare or make alpha_env_prepare; link creates dev/env-overrides/<env>/*.env pointing at home.

MANAGEMENT_SUPERUSER_EMAIL=
MANAGEMENT_SUPERUSER_PASSWORD=
