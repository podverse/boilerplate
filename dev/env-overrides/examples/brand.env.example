# Brand name and app title icon. Set from this file by make local_env_setup (local) or merged into K8s manifests (alpha/beta/prod).
# api/web = BRAND_NAME. mgmt api/mgmt web = MANAGEMENT_BRAND_NAME. Do not set NEXT_PUBLIC_BRAND_NAME in overrides.
# Canonical example in dev/env-overrides/examples/. Seeded to ~/.config/boilerplate/<local-env-overrides|alpha-env-overrides>/ by make local_env_prepare or make alpha_env_prepare; link creates dev/env-overrides/<env>/*.env pointing at home.

BRAND_NAME="boilerplate-web"
MANAGEMENT_BRAND_NAME="boilerplate-management-web"
# Font Awesome icon class for app title (web, management-web). Omit or leave empty for no icon.
NEXT_PUBLIC_APP_TITLE_ICON="fa-solid fa-bolt"
