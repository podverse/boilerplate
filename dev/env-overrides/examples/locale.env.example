# Locale defaults. One place for all apps; local setup applies to API, web, management-api, management-web (including sidecars). Do not set these in other override files.
# API/management-api use DEFAULT_LOCALE and SUPPORTED_LOCALES. Web/management-web sidecars use NEXT_PUBLIC_DEFAULT_LOCALE and NEXT_PUBLIC_SUPPORTED_LOCALES.
# Canonical example in dev/env-overrides/examples/. Seeded to ~/.config/boilerplate/<local-env-overrides|alpha-env-overrides>/ by make local_env_prepare or make alpha_env_prepare; link creates dev/env-overrides/<env>/*.env pointing at home.

DEFAULT_LOCALE="en-US"
SUPPORTED_LOCALES="all-available"
NEXT_PUBLIC_DEFAULT_LOCALE="en-US"
NEXT_PUBLIC_SUPPORTED_LOCALES="all-available"
