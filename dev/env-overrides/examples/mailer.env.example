# Mailer (SMTP). No defaults — bring your own. Applied to API by make local_env_setup when present (local), or merged into K8s API secrets when set (alpha/beta/prod).
# Tests/CI use mailpit.
# Canonical example in dev/env-overrides/examples/. Seeded to ~/.config/boilerplate/<local-env-overrides|alpha-env-overrides>/ by make local_env_prepare or make alpha_env_prepare; link creates dev/env-overrides/<env>/*.env pointing at home.

SMTP_HOST=
SMTP_PORT=
MAIL_FROM=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=
