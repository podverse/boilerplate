# Brand name and app title icon. Set from this file by make local_env_setup.
# api/web = BRAND_NAME. mgmt api/mgmt web = MANAGEMENT_BRAND_NAME. Do not set NEXT_PUBLIC_BRAND_NAME in overrides.
# Prepared by local_env_prepare; edit in ~/.config/boilerplate/local-env-overrides/ after link.

BRAND_NAME="boilerplate-web"
MANAGEMENT_BRAND_NAME="boilerplate-management-web"
# Font Awesome icon class for app title (web, management-web). Omit or leave empty for no icon.
NEXT_PUBLIC_APP_TITLE_ICON="fa-solid fa-bolt"
