# Locale defaults. One place for all apps; setup applies to API, web, management-api, management-web (including sidecars). Do not set these in other override files.
# API/management-api use DEFAULT_LOCALE and SUPPORTED_LOCALES. Web/management-web sidecars use NEXT_PUBLIC_DEFAULT_LOCALE and NEXT_PUBLIC_SUPPORTED_LOCALES.
# Prepared by local_env_prepare; edit in ~/.config/boilerplate/local-env-overrides/ after link.

DEFAULT_LOCALE="en-US"
SUPPORTED_LOCALES="all-available"
NEXT_PUBLIC_DEFAULT_LOCALE="en-US"
NEXT_PUBLIC_SUPPORTED_LOCALES="all-available"
