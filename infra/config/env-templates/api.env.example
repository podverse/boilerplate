#####
##### boilerplate-api (Docker / infra/config/local)
##### Copy to apps/api/.env for local dev, or to infra/config/local/api.env for Docker.
##### Keep in sync with apps/api/.env.example (section order and variables).
#####

# Port the API listens on (required)
API_PORT="4000"

# Application name (required), e.g. used in /health
APP_NAME="boilerplate-api"

# Database (required). Use read and read_write users (see infra/config/env-templates/db.env.example).
# Docker: DB_HOST=postgres, DB_PORT=5432. Local dev (API on host, Postgres in Docker): DB_HOST=localhost, DB_PORT=5433
DB_HOST="postgres"
DB_PORT="5432"
DB_NAME="postgres"
DB_READ_USERNAME="read"
DB_READ_PASSWORD="changeme_read"
DB_READ_WRITE_USERNAME="read_write"
DB_READ_WRITE_PASSWORD="changeme_read_write"

# Valkey (required for features that use it). For Docker: VALKEY_HOST=valkey. From host: VALKEY_PORT=6380
VALKEY_HOST="valkey"
VALKEY_PORT="6379"
