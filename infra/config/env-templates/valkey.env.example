#####
##### Boilerplate Valkey – used by API for message storage (plan 22).
##### Copy to infra/config/local/valkey.env or merge into api.env.
##### Valkey is configured to require this password; API and any client must set VALKEY_PASSWORD to connect.
#####

# Required. Set by: make env_setup
VALKEY_PASSWORD=

# Docker: VALKEY_HOST=valkey, VALKEY_PORT=6379. Local dev (API on host): VALKEY_HOST=localhost, VALKEY_PORT=6380
VALKEY_HOST="valkey"
VALKEY_PORT="6379"
