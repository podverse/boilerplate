#####
##### Boilerplate DB – used by Postgres container and by API/ORM when running in Docker.
##### Copy to infra/config/local/db.env.
#####

# Postgres container (docker-compose postgres service). Standard superuser/database names.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="postgres"
# Required for 01_create_users.sh (read-only and read-write roles)
POSTGRES_READ_PASSWORD="changeme_read"
POSTGRES_READ_WRITE_PASSWORD="changeme_read_write"

# API/ORM connection (use read and read_write users)
# Docker: DB_HOST=postgres, DB_PORT=5432. Local dev (API on host): DB_HOST=localhost, DB_PORT=5433
DB_HOST="postgres"
DB_PORT="5432"
DB_NAME="postgres"

# Read-only user (for future read-heavy/reporting paths)
DB_READ_USERNAME="read"
DB_READ_PASSWORD="changeme_read"

# Read-write user (default for API/ORM)
DB_READ_WRITE_USERNAME="read_write"
DB_READ_WRITE_PASSWORD="changeme_read_write"

# Optional: single URL for drivers that support it (use read-write credentials)
# DATABASE_URL="postgresql://read_write:changeme_read_write@postgres:5432/postgres"
