#####
##### Boilerplate DB – used by Postgres container and by API/ORM when running in Docker.
##### Copy to infra/config/local/db.env. Passwords are generated by: make local_env_setup
#####

# Postgres container (docker-compose postgres service). Standard superuser/database names.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD=
POSTGRES_DB="postgres"

# API/ORM connection and init script (01_create_users.sh) both use these.
# Docker: DB_HOST=postgres, DB_PORT=5432. Local dev (API on host): DB_HOST=localhost, DB_PORT=5433
DB_HOST="postgres"
DB_PORT="5432"
DB_NAME="postgres"

# Read-only and read-write user passwords. Used by 01_create_users.sh to create roles and by API/ORM to connect.
DB_READ_USERNAME="read"
DB_READ_PASSWORD=
DB_READ_WRITE_USERNAME="read_write"
DB_READ_WRITE_PASSWORD=

# Optional: single URL for drivers that support it (use read-write credentials)
# DATABASE_URL="postgresql://read_write:PASSWORD@postgres:5432/postgres"
