#####
##### Boilerplate DB – used by Postgres container and by API/ORM when running in Docker.
##### Copy to infra/config/local/db.env. Passwords are generated by: make local_env_setup
#####
##### Two databases in one Postgres instance (aligned with Podverse): app DB and management DB.
##### POSTGRES_DB = app DB; POSTGRES_MANAGEMENT_DB = management DB (identities/permissions).
##### DB user names align with Podverse: POSTGRES_READ_USER / POSTGRES_READ_WRITE_USER (app);
##### POSTGRES_MANAGEMENT_READ_USER / POSTGRES_MANAGEMENT_READ_WRITE_USER (management).
#####

# Postgres container: creates initial database from POSTGRES_DB. Init scripts create management DB.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD=
POSTGRES_DB="boilerplate_app"
POSTGRES_MANAGEMENT_DB="boilerplate_management"

# App DB roles (Podverse-style; used by 01_create_users.sh and by API/ORM via DB_* vars below).
POSTGRES_READ_USER="boilerplate_app_read"
POSTGRES_READ_PASSWORD=
POSTGRES_READ_WRITE_USER="boilerplate_app_read_write"
POSTGRES_READ_WRITE_PASSWORD=

# Management DB roles (used by 02_init_management_db.sh and management-api via MANAGEMENT_DB_USERNAME).
POSTGRES_MANAGEMENT_READ_USER="boilerplate_management_read"
POSTGRES_MANAGEMENT_READ_PASSWORD=
POSTGRES_MANAGEMENT_READ_WRITE_USER="boilerplate_management_read_write"
POSTGRES_MANAGEMENT_READ_WRITE_PASSWORD=

# API/ORM connection and init script (01_create_users.sh) both use these.
# Docker: DB_HOST=postgres, DB_PORT=5432. Local dev (API on host): DB_HOST=localhost, DB_PORT=5433
DB_HOST="postgres"
DB_PORT="5432"
DB_NAME="boilerplate_app"

# Management DB name (used by init scripts and management-api; same as POSTGRES_MANAGEMENT_DB).
MANAGEMENT_DB_NAME="boilerplate_management"
MANAGEMENT_DB_USERNAME="boilerplate_management_read_write"

# App-facing DB user names (same values as POSTGRES_*_USER; apps read these).
DB_READ_USERNAME="boilerplate_app_read"
DB_READ_PASSWORD=
DB_READ_WRITE_USERNAME="boilerplate_app_read_write"
DB_READ_WRITE_PASSWORD=

# Optional: single URL for drivers that support it (use read-write credentials)
# DATABASE_URL="postgresql://boilerplate_app_read_write:PASSWORD@postgres:5432/boilerplate_app"
