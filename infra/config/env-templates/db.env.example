#####
##### Metaboost DB – used by Postgres container and by API/ORM when running in Docker.
##### Copy to infra/config/local/db.env.
#####

# Postgres container (docker-compose postgres service)
POSTGRES_USER="metaboost"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="metaboost"

# API/ORM connection (same values; DB_HOST=postgres for Docker)
DB_HOST="postgres"
DB_PORT="5432"
DB_NAME="metaboost"
DB_USER="metaboost"
DB_PASSWORD="changeme"

# Optional: single URL for drivers that support it
# In Docker: postgres:5432. From host: localhost:5433
# DATABASE_URL="postgresql://metaboost:changeme@postgres:5432/metaboost"
