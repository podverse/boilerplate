#####
##### boilerplate-web (Docker / infra/config/local)
##### Copy to apps/web/.env.local for local dev, or to infra/config/local/web.env for Docker.
##### Keep in sync with apps/web/.env.example (section order and variables).
#####

# Port the Next.js dev server listens on (optional; default 3000 if unset)
PORT="4100"

# URL of the runtime-config sidecar (e.g. http://localhost:4101). Optional; if unset, app uses process.env.
RUNTIME_CONFIG_URL="http://localhost:4101"

# Example public env (exposed to client). When using sidecar, these are served by the sidecar.
NEXT_PUBLIC_APP_NAME="boilerplate-web"
NEXT_PUBLIC_API_URL="http://localhost:4000"
