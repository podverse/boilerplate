# Signup-enabled E2E: API env vars when running against E2E Mailpit.
# The API is started by Playwright with these values (see apps/web/playwright.signup-enabled.config.ts).
# Copy to .env in this directory only if you need to reference from tooling; Playwright config sets them inline.

MAILER_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=test@test.com
APP_BASE_URL=http://localhost:4010
