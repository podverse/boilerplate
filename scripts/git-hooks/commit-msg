#!/bin/bash

# Boilerplate Commit Message Hook
# Outputs to stderr so messages appear in GUI error dialogs

YELLOW='\033[1;33m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
NC='\033[0m'

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Allow merge commits without issue reference
if echo "$COMMIT_MSG" | grep -qE '^Merge '; then
  exit 0
fi

if echo "$COMMIT_MSG" | grep -qE '#[0-9]+'; then
  exit 0
fi

echo "" >&2
echo -e "${YELLOW}╔════════════════════════════════════════════════════════════╗${NC}" >&2
echo -e "${YELLOW}║  🔗 No GitHub issue reference in commit message            ║${NC}" >&2
echo -e "${YELLOW}╚════════════════════════════════════════════════════════════╝${NC}" >&2
echo -e "${CYAN}Message:${NC} $COMMIT_MSG" >&2
echo "" >&2

if [ -t 0 ]; then
  echo -e "${CYAN}Options:${NC} [Enter] Continue | [e] Add issue | [a] Abort" >&2
  read -p "Choice: " -n 1 -r REPLY < /dev/tty
  echo "" >&2
  case $REPLY in
    [eE])
      echo -e "${CYAN}Issue number(s):${NC}" >&2
      read -r ISSUE_REFS < /dev/tty
      [[ -n "$ISSUE_REFS" ]] && echo -e "\n$ISSUE_REFS" >> "$COMMIT_MSG_FILE"
      exit 0
      ;;
    [aA])
      echo "Aborted." >&2
      exit 1
      ;;
    *) exit 0 ;;
  esac
else
  # Non-interactive (GUI) - block commit
  echo "❌ Commit blocked: No GitHub issue reference (e.g., #123) in commit message." >&2
  echo "   Use terminal to commit with interactive options, or add issue reference." >&2
  exit 1
fi
