#####
##### Boilerplate API
##### Copy to .env (local) or infra/config/local/api.env (Docker) and set values.
#####

# Port the API listens on (required)
API_PORT="4000"

# Brand name (required), e.g. used in /health. Set from dev/env-overrides/local/brand.env by local_env_setup or set directly.
BRAND_NAME="boilerplate-api"
# User-Agent for outbound HTTP (optional). When blank, built from BRAND_NAME: BrandName Bot Local/API/1.
USER_AGENT=

# API version path prefix for all versioned routes (optional). No trailing slash.
API_VERSION_PATH="/v1"

# Public base URL for the app (e.g. https://api.example.com). Used for verification links (mailer flows). Required when AUTH_MODE is admin_only_email or user_signup_email.
APP_BASE_URL=

# Locale for user-facing content (emails, password validation). Set from dev/env-overrides/local/locale.env by local_env_setup.
DEFAULT_LOCALE="en-US"
# Comma-separated supported locales (e.g. en-US,es) or all-available for all. Set from dev/env-overrides/local/locale.env by local_env_setup.
SUPPORTED_LOCALES=

# Auth: JWT secret (required). Min 32 characters. Set by: make local_env_setup
JWT_SECRET=

# Session cookies (required). Use these defaults or set your own. Access/session is short-lived; refresh is long-lived.
SESSION_COOKIE_NAME="session"
REFRESH_COOKIE_NAME="refresh"
# Access token expiry in seconds (required). Used for both JWT and cookie max-age. Web: 1 month so session stays valid 1 month.
JWT_ACCESS_EXPIRY_SECONDS="2592000"
JWT_REFRESH_EXPIRY_SECONDS="2592000"
# SameSite: lax | strict | none (required). Use none only for cross-origin with Secure.
COOKIE_SAME_SITE="lax"
# CORS: comma-separated origins (optional). Empty = allow all. With cookies use explicit origins.
CORS_ORIGINS=

# Auth mode (required): admin_only_username | admin_only_email | user_signup_email. Set from dev/env-overrides/local/auth.env by local_env_setup.
# admin_only_username: signup disabled; all email-based auth flows disabled.
# admin_only_email: signup disabled; forgot/reset/email-change/verify enabled.
# user_signup_email: self-service signup + email flows enabled.
# MAILER_ENABLED is intentionally not used; mailer requirement is derived from AUTH_MODE.
AUTH_MODE="admin_only_username"

# Mailer (required when AUTH_MODE is admin_only_email or user_signup_email). Set from dev/env-overrides/local/mailer.env by local_env_setup when present; no defaults (devs bring their own; tests use mailpit).
SMTP_HOST=
SMTP_PORT=
MAIL_FROM=
# SMTP auth (optional): SMTP_USER=, SMTP_PASSWORD=, SMTP_SECURE=false

# Database (required). Use read and read_write users. Set by: make local_env_setup
# Docker: DB_HOST=postgres, DB_PORT=5432. Local dev (API on host, Postgres in Docker): DB_HOST=localhost, DB_PORT=5433.
# Tests/CI use port 5532 to avoid conflict with Podverse monorepo (5432).
DB_HOST="postgres"
DB_PORT="5432"
DB_NAME="postgres"
DB_READ_USERNAME="read"
DB_READ_PASSWORD=
DB_READ_WRITE_USERNAME="read_write"
DB_READ_WRITE_PASSWORD=

# Valkey (required for features that use it). Set by: make local_env_setup
# Docker: VALKEY_HOST=valkey, VALKEY_PORT=6379. Local dev (API on host): VALKEY_HOST=localhost, VALKEY_PORT=6380.
# Tests/CI use port 6479 to avoid conflict with Podverse monorepo (6379).
VALKEY_HOST="valkey"
VALKEY_PORT="6379"
VALKEY_PASSWORD=
