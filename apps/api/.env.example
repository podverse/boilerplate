#####
##### Boilerplate API
##### Copy to .env (local) or infra/config/local/api.env (Docker) and set values.
#####

# Port the API listens on (required)
API_PORT="4000"

# Application name (required), e.g. used in /health
APP_NAME="boilerplate-api"

# Database (required). For Docker: DB_HOST=postgres. From host: DB_HOST=localhost, DB_PORT=5433
DB_HOST="postgres"
DB_PORT="5432"
DB_NAME="boilerplate"
DB_USER="boilerplate"
DB_PASSWORD="changeme"

# Valkey (required for features that use it). For Docker: VALKEY_HOST=valkey. From host: VALKEY_PORT=6380
VALKEY_HOST="valkey"
VALKEY_PORT="6379"
