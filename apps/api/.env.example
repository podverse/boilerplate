#####
##### Boilerplate API
##### Copy to .env (local) or infra/config/local/api.env (Docker) and set values.
#####

# Port the API listens on (required)
API_PORT="4000"

# Application name (required), e.g. used in /health
APP_NAME="boilerplate-api"

# API version path prefix for all versioned routes (optional). No trailing slash.
API_VERSION_PATH="/v1"

# Public base URL for the app (e.g. https://api.example.com). Used for verification links (mailer) and may be used elsewhere. Required when MAILER_ENABLED=true.
APP_BASE_URL=

# Locale for user-facing content (emails, password validation). Optional. Unset = en-US. Used when Accept-Language is missing or unsupported.
DEFAULT_LOCALE="en-US"
# Comma-separated supported locales (e.g. en-US,es) or empty/all-available for all.
SUPPORTED_LOCALES=

# Auth: JWT secret (required). Min 32 characters. Set by: make env_setup
JWT_SECRET=

# Session cookies (required). Use these defaults or set your own. Access/session is short-lived; refresh is long-lived.
SESSION_COOKIE_NAME="session"
REFRESH_COOKIE_NAME="refresh"
# Access token expiry in seconds (required). Used for both JWT and cookie max-age. Web: 1 month so session stays valid 1 month.
JWT_ACCESS_EXPIRY_SECONDS="2592000"
JWT_REFRESH_EXPIRY_SECONDS="2592000"
# SameSite: lax | strict | none (required). Use none only for cross-origin with Secure.
COOKIE_SAME_SITE="lax"
# CORS: comma-separated origins (optional). Empty = allow all. With cookies use explicit origins.
CORS_ORIGINS=

# Auth mode: set MAILER_ENABLED=true when mailer is configured to enable self-service signup (POST /auth/signup).
# When mailer is disabled (default or AUTH_MODE=admin_only), signup is disabled; user creation is via the Management API when the Management track is in use.
AUTH_MODE=admin_only
MAILER_ENABLED=

# Mailer (required when MAILER_ENABLED=true): SMTP for sending email
SMTP_HOST=
SMTP_PORT=
MAIL_FROM=
# SMTP auth (optional): SMTP_USER=, SMTP_PASSWORD=, SMTP_SECURE=false

# Database (required). Use read and read_write users. Set by: make env_setup
# Docker: DB_HOST=postgres, DB_PORT=5432. Local dev (API on host, Postgres in Docker): DB_HOST=localhost, DB_PORT=5433.
# Tests/CI use port 5532 to avoid conflict with Podverse monorepo (5432).
DB_HOST="postgres"
DB_PORT="5432"
DB_NAME="postgres"
DB_READ_USERNAME="read"
DB_READ_PASSWORD=
DB_READ_WRITE_USERNAME="read_write"
DB_READ_WRITE_PASSWORD=

# Valkey (required for features that use it). Set by: make env_setup
# Docker: VALKEY_HOST=valkey, VALKEY_PORT=6379. Local dev (API on host): VALKEY_HOST=localhost, VALKEY_PORT=6380.
# Tests/CI use port 6479 to avoid conflict with Podverse monorepo (6379).
VALKEY_HOST="valkey"
VALKEY_PORT="6379"
VALKEY_PASSWORD=
