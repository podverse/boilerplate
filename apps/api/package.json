{
  "name": "@boilerplate/api",
  "version": "0.1.2",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node ./dist/index.js",
    "dev:watch": "tsc && concurrently \"tsc --watch --preserveWatchOutput\" \"sleep 4 && nodemon --delay 2500ms --watch dist --watch ../../packages/helpers/dist --watch ../../packages/orm/dist node dist/index.js\"",
    "start": "node ./dist/index.js",
    "lint": "eslint ./src --max-warnings 0",
    "lint:fix": "eslint ./src --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@boilerplate/helpers": "*",
    "@boilerplate/orm": "*",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.12",
    "concurrently": "^9.2.1",
    "dotenv": "^16.4.5",
    "nodemon": "^3.1.10",
    "typescript": "^5.9.2"
  }
}
