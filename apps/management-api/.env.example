#####
##### Boilerplate Management API
##### Copy to .env (local) or infra config and set values.
#####

# Port the Management API listens on (required)
MANAGEMENT_API_PORT="4100"

# Brand name (required). Set from dev/env-overrides/local/brand.env by local_env_setup or set directly.
BRAND_NAME="boilerplate-management-api"
# User-Agent for outbound HTTP (optional). When blank, built from BRAND_NAME: BrandName Bot Local/Management-API/1.
USER_AGENT=

# API version path prefix for versioned routes (optional). No trailing slash.
MANAGEMENT_API_VERSION_PATH="/v1"

# Auth mode (required): admin_only_username | admin_only_email | user_signup_email. Set from dev/env-overrides/local/auth.env by local_env_setup.
# Must match API AUTH_MODE so management behavior aligns with public auth capabilities.
AUTH_MODE="admin_only_username"

# Auth: JWT secret (required). Min 32 characters.
MANAGEMENT_JWT_SECRET=

# Session cookies (required). Use these defaults or set your own.
MANAGEMENT_SESSION_COOKIE_NAME="management_session"
MANAGEMENT_REFRESH_COOKIE_NAME="management_refresh"
# Access token expiry in seconds (required). Used for both JWT and cookie max-age. Management-web: 1 hour so session stays valid 1 hour.
MANAGEMENT_JWT_ACCESS_EXPIRY_SECONDS="3600"
MANAGEMENT_JWT_REFRESH_EXPIRY_SECONDS="3600"
# Invitation/set-password link expiry in hours (required). Default: 24h.
# Used when management creates a user without a password in admin-only modes.
USER_INVITATION_TTL_HOURS="24"
# SameSite: lax | strict | none (required).
MANAGEMENT_COOKIE_SAME_SITE="lax"
# CORS: comma-separated origins (optional). Empty = allow all.
MANAGEMENT_CORS_ORIGINS=

# Management DB (required). Dedicated DB for management identities/permissions.
MANAGEMENT_DB_HOST="localhost"
MANAGEMENT_DB_PORT="5532"
MANAGEMENT_DB_NAME="boilerplate_management"
MANAGEMENT_DB_USERNAME="read_write"
MANAGEMENT_DB_PASSWORD=

# Main web app base URL (optional). Used for set-password/invitation links for admin-only modes.
WEB_APP_URL=

# Main app DB (required). Management API needs read/write to main DB for user creation etc.
DB_HOST="localhost"
DB_PORT="5532"
DB_NAME="postgres"
DB_READ_USERNAME="read"
DB_READ_PASSWORD=
DB_READ_WRITE_USERNAME="read_write"
DB_READ_WRITE_PASSWORD=
