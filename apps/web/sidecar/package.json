{
  "name": "@metaboost/web-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Runtime-config sidecar for Metaboost web",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "bundle": "esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "typescript": "^5.9.2"
  }
}
