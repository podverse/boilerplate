#####
##### Boilerplate Web runtime-config sidecar
#####
# Full env for the sidecar that serves runtime config. The app .env.example has only RUNTIME_CONFIG_URL.

# Port the sidecar listens on (required; startup validation fails if missing or invalid).
PORT="4001"

# Brand name (exposed to client). Set from dev/env-overrides/local/brand.env by local_env_setup. When using sidecar, served by the sidecar.
NEXT_PUBLIC_BRAND_NAME="boilerplate-web"
# Optional: Base URL of this web app (e.g. http://localhost:4002). Use when constructing full URLs (e.g. invite links in emails). No trailing slash. Same concept as management-web NEXT_PUBLIC_WEB_APP_URL.
NEXT_PUBLIC_WEB_APP_URL="http://localhost:4002"
# Font Awesome icon class for the app title (e.g. fa-solid fa-bolt). Set from dev/env-overrides/local/brand.env by local_env_setup.
NEXT_PUBLIC_APP_TITLE_ICON="fa-solid fa-bolt"
NEXT_PUBLIC_API_URL="http://localhost:4000"
# API version path (e.g. /v1). Must start with /. Default in env; align with API_VERSION_PATH on the API.
NEXT_PUBLIC_API_VERSION_PATH="/v1"
# Auth mode (must match AUTH_MODE on the API). Controls which auth routes are available client-side.
NEXT_PUBLIC_AUTH_MODE="admin_only_username"
# Session refresh interval in ms (required). Must be less than JWT_ACCESS_EXPIRY_SECONDS * 1000. E.g. 600000 = 10 min for 1-month access.
NEXT_PUBLIC_SESSION_REFRESH_INTERVAL_MS="600000"
# Backend URL for server-side API calls (not exposed to browser).
# Docker local default: API container DNS on the compose network.
# k3d local: overridden in k8s workloads to http://api:4000.
# Falls back to NEXT_PUBLIC_API_URL if not set. No trailing slash.
API_BACKEND_URL="http://boilerplate_local_api:4000"

# i18n: default locale when none is detected. Set from dev/env-overrides/local/locale.env by local_env_setup.
NEXT_PUBLIC_DEFAULT_LOCALE="en-US"
# i18n: "all-available" = use all hardcoded locales; else comma-delimited list. Set from dev/env-overrides/local/locale.env by local_env_setup.
NEXT_PUBLIC_SUPPORTED_LOCALES="all-available"
