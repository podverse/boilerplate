#####
##### Boilerplate Web
##### Copy to .env.local (or .env) and set values.
#####

# Port the Next.js dev server listens on (optional; default 4002 if unset)
PORT="4002"

# URL of the runtime-config sidecar (e.g. http://localhost:4001). Optional; if unset, app uses process.env.
RUNTIME_CONFIG_URL="http://localhost:4001"

# Example public env (exposed to client). When using sidecar, these are served by the sidecar.
NEXT_PUBLIC_APP_NAME="boilerplate-web"
# Font Awesome icon class for the app title (e.g. fa-solid fa-bolt). Omit or leave empty for no icon.
NEXT_PUBLIC_APP_TITLE_ICON="fa-solid fa-bolt"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# i18n: default locale when none is detected (default: en-US)
DEFAULT_LOCALE="en-US"
# i18n: "all-available" = use all hardcoded locales; else comma-delimited list (e.g. "en-US,es")
SUPPORTED_LOCALES="all-available"
