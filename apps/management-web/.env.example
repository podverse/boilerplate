#####
##### Boilerplate Management Web
##### Copy to .env.local (or .env) and set values.
#####

# Port the Next.js dev server listens on (optional)
PORT="4102"

# Base URL of the management API (exposed to client). No trailing slash.
NEXT_PUBLIC_MANAGEMENT_API_URL="http://localhost:4100"
# API version path prefix (e.g. /v1). Must start with /.
NEXT_PUBLIC_MANAGEMENT_API_VERSION_PATH="/v1"
# Font Awesome icon class for the app title (e.g. fa-solid fa-bolt). Omit or leave empty for no icon.
NEXT_PUBLIC_APP_TITLE_ICON="fa-solid fa-bolt"

# i18n: default locale when none is detected (default: en-US)
DEFAULT_LOCALE="en-US"
# i18n: "all-available" = use all hardcoded locales; else comma-delimited list (e.g. "en-US,es")
SUPPORTED_LOCALES="all-available"
