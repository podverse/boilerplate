#####
##### Boilerplate Management Web
#####
# Copy to .env.local (or .env) and set RUNTIME_CONFIG_URL.
# When using the runtime-config sidecar, this is the only var the app process needs;
# all other config is loaded from the sidecar at runtime.
# For the full variable list, see: apps/management-web/sidecar/.env.example

#####
##### Runtime Config Sidecar
#####
# URL of the runtime-config sidecar (e.g. http://localhost:4101)
RUNTIME_CONFIG_URL="http://localhost:4101"
