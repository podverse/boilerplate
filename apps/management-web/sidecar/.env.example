#####
##### Boilerplate Management Web runtime-config sidecar
#####
# Full env for the sidecar that serves runtime config. The app .env.example has only RUNTIME_CONFIG_URL.

# Port the sidecar server listens on (optional; default 4101 if unset)
PORT="4101"

# Base URL of the management API (exposed to client). No trailing slash.
# For k3d local: absolute URL for direct browser access via k3d port mapping.
# For production with a reverse proxy routing /api/management to management-api: use "/api/management".
NEXT_PUBLIC_MANAGEMENT_API_URL="http://localhost:4100"
# Backend URL for server-side auth (proxy, getServerUser). For k3d: k8s-internal DNS. No trailing slash.
# Must be set when NEXT_PUBLIC_MANAGEMENT_API_URL is a direct absolute URL (not a same-origin proxy path).
MANAGEMENT_API_BACKEND_URL="http://localhost:4100"
# API version path prefix (e.g. /v1). Must start with /.
NEXT_PUBLIC_MANAGEMENT_API_VERSION_PATH="/v1"
# Session refresh interval in ms (required).
NEXT_PUBLIC_MANAGEMENT_SESSION_REFRESH_INTERVAL_MS="1800000"
# Brand name (exposed to client). Set from dev/env-overrides/local/brand.env (MANAGEMENT_BRAND_NAME) by local_env_setup.
NEXT_PUBLIC_BRAND_NAME=
# Font Awesome icon class for the app title. Set from dev/env-overrides/local/brand.env by local_env_setup.
NEXT_PUBLIC_APP_TITLE_ICON="fa-solid fa-bolt"
# Base URL of the main web app (e.g. http://localhost:4002). No trailing slash.
NEXT_PUBLIC_WEB_APP_URL="http://localhost:4002"

# i18n: default locale when none is detected.
NEXT_PUBLIC_DEFAULT_LOCALE="en-US"
# i18n: "all-available" = use all hardcoded locales; else comma-delimited list.
NEXT_PUBLIC_SUPPORTED_LOCALES="all-available"
